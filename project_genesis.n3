@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix qualia: <http://qualia.local/ns/logic#> .
@prefix didgit: <http://webcivics.github.io/did-method-git#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# DID:GIT Genesis Block (Stage 1 Axioms)
<did:git:repo:qualia_analytics_engine> a doap:Project ;
    doap:name "Primary Analytics Demographic Model" ;
    doap:description "An N3Logic demographic mapping tool." ;
    didgit:stage "1"^^xsd:integer ;
    
    # The Rights Ontology for Stage 1
    qualia:hasRightsOntology [
        qualia:knowledgeAxioms "Protected" ;
        qualia:commercialGating "Strict" ;
        qualia:obligationCost "500000"^^xsd:integer ; # micro-cents
        
        # Legal and Philosophical Axioms
        qualia:legalFramework [
            qualia:principal "Natural Person" ;
            qualia:agent "Digital Software Client (WellFair)" ;
            qualia:relationship "Principal-Agent Duty of Care"
        ] ;
        
        qualia:foundationalModels [
            qualia:supportedModels "Maslows_Hierarchy", "Systems_of_Faith", "Pluralistic_Welfare_Models"
        ] ;
        
        qualia:linguisticPlurality [
            qualia:motherTongues "Supported" ;
            qualia:languagesOfPrayer "Supported" ;
            qualia:nonWrittenFormats "Audio_Phonetic", "Ceremonial_Heraldry", "Symbolic_Visual"
        ]
    ] ;

    # The Transition Rule for Stage 2
    qualia:evolutionPredicate [
        qualia:targetStage "2"^^xsd:integer ;
        qualia:requires [
            qualia:ilpAccumulated qualia:GreaterThanOrEqual "500000"^^xsd:integer
        ]
    ] .
