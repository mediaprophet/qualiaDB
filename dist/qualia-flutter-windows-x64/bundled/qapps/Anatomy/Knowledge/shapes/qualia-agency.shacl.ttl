@prefix q42: <https://qualia.id/ns/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---------------------------------------------------------------------------
# Agency alignment: a human being (Principal) may HAVE things but IS NOT a Thing.
# Clinical / anatomical / imaging artefacts are q42:Thing subclasses.
# ---------------------------------------------------------------------------

q42:Principal a owl:Class ;
    rdfs:label "Principal (natural legal person)" ;
    rdfs:comment "A human being acting with agency. Not a subclass of owl:Thing or q42:Thing." .

q42:Thing a owl:Class ;
    rdfs:label "Reifiable entity" ;
    rdfs:comment "Clinical findings, anatomical structures, imaging series, documents — possessions of a Principal." .

q42:ClinicalEntity a owl:Class ;
    rdfs:subClassOf q42:Thing ;
    rdfs:label "Clinical entity" .

q42:ImagingEntity a owl:Class ;
    rdfs:subClassOf q42:Thing ;
    rdfs:label "DICOM information entity (study/series/image)" .

q42:hasCondition a owl:ObjectProperty ;
    rdfs:domain q42:Principal ;
    rdfs:range q42:ClinicalEntity ;
    rdfs:comment "Principal possesses a condition; the Principal is not the condition." .

q42:hasFinding a owl:ObjectProperty ;
    rdfs:domain q42:Principal ;
    rdfs:range q42:ClinicalEntity .

q42:hasImagingStudy a owl:ObjectProperty ;
    rdfs:domain q42:Principal ;
    rdfs:range q42:ImagingEntity .

q42:hasDicomSeries a owl:ObjectProperty ;
    rdfs:domain q42:Principal ;
    rdfs:range q42:ImagingEntity .

# --- SHACL gates (compiled by shacl_compiler.rs → Webizen VM) ---

q42:PrincipalShape a sh:NodeShape ;
    sh:targetClass q42:Principal ;
    sh:not [
        sh:targetClass q42:Thing ;
        sh:message "A Principal (human being) must not be typed as a Thing." ;
    ] ;
    sh:not [
        sh:targetClass owl:Thing ;
        sh:message "A Principal must not be typed as owl:Thing." ;
    ] ;
    sh:property [
        sh:path q42:hasCondition ;
        sh:class q42:ClinicalEntity ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:minCount 0 ;
        sh:message "Conditions are possessions of the Principal, not identity of the Principal." ;
    ] ;
    sh:property [
        sh:path q42:hasFinding ;
        sh:class q42:ClinicalEntity ;
        sh:minCount 0 ;
    ] ;
    sh:property [
        sh:path q42:hasImagingStudy ;
        sh:class q42:ImagingEntity ;
        sh:minCount 0 ;
    ] .

q42:ClinicalEntityShape a sh:NodeShape ;
    sh:targetClass q42:ClinicalEntity ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
