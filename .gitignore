# Claude Code session files (dev-machine only)
.claude/

# Python bytecode cache
__pycache__/
*.pyc

# WordNet build artefacts (large downloaded data, not source)
scripts/.wordnet_build/

# Massive LLM Weights & Models
*.gguf
gemma-4-E4B-it-GGUF/

# wasm-pack output (copied to docs/playground/ manually or by pages.yml)
crates/qualia-core-db/pkg/

# Generated Rust API docs staged for Jekyll (CI only)
docs/rustdoc/

# Vendored Node.js binary (local tooling only, not needed in repo)
node_dist/
node.zip

# Local build outputs (Flutter packaging moved to WebizenAI repo)
/dist/
/releases/

# Local Libraries (export staging — see Local_LIbraries/EXPORTS/README.md)
Local_Libraries/

# App development sandbox (wellfair, cooperative-projects — not part of the core release)
qapp-development/
app-development/

# Signing keystore — never commit private keys
keystore.bin

# One-off migration scripts, old release binaries, debug artefacts
scratch/

# QPU internal functionality (undocumented, private)
qpu/

# Private research documents (not for public repository)
private/

# Local development files (completed planning, temporary docs, etc.)
local/
legacy/
ingest_raw.wal.tmp
yago-tests/large-file-results/*.ttl
