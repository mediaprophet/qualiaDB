@prefix radlex: <http://www.radlex.org/RID/> .

# Generated from RadLex OWL — anatomical possession graph (Things, not Principals)

radlex:AnatomicalEntity a owl:Class ;
rdfs:subClassOf q42:Thing ;
rdfs:comment "RadLex RID tokens are clinical Things a Principal may have findings about." .

radlex:RID1000Shape a sh:NodeShape ;
    sh:targetClass radlex:RID1000 ;
    sh:class radlex:AnatomicalEntity ;
    sh:property [ sh:path radlex:Branch_Of ; sh:hasValue radlex:RID998 ] ;
    sh:property [ sh:path radlex:Part_Of ; sh:hasValue radlex:RID13183 ] .

