{
  "build": {
    "devPath": "http://localhost:5173",
    "distDir": "../qualia-client/dist"
  },
  "package": {
    "productName": "Qualia Desktop",
    "version": "0.0.10"
  },
  "tauri": {
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "allowlist": {
      "all": false,
      "os": { "all": true },
      "protocol": { "asset": true, "assetScope": ["**"] }
    },
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "PLACEHOLDER_REPLACE_WITH_TAURI_SIGN_PUBLIC_KEY",
      "endpoints": [
        "https://mediaprophet.github.io/qualiaDB/releases/latest.json"
      ]
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": { "depends": [] },
      "macOS": {
        "minimumSystemVersion": "11.0"
      },
      "identifier": "com.qualia.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [],
      "windows": {
        "allowDowngrades": true,
        "nsis": {
          "installMode": "currentUser"
        }
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Qualia Desktop Agent",
        "width": 1200,
        "visible": false
      }
    ]
  }
}
