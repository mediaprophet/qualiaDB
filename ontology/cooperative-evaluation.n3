# Enhanced Evaluation Rules with Project Approaches & Technical Debt

@prefix qp: <https://qualia.org/ontology/cooperative-projects#> .
@prefix wf: <https://wellfair.org/ns#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .

# Classify Approach
{ ?proj qp:hasApproach ?approach } => { ?proj wf:approachType ?approach } .

# Technical Debt Impact on Reputation & Multiplier
{ ?proj qp:technicalDebtLevel ?debt .
  ?debt > 0.6 } => { ?proj qp:expectedMultiplier ?adj .
    ?proj qp:expectedMultiplier 0.7 math:product ?adj . } .

# Reward Multiplier Calculation
{ ?idea qp:riskFactor ?risk ;
  qp:expectedMultiplier ?base .
} => { ?idea qp:finalMultiplier ?final .
  (?base (?risk 0.4 math:product)) math:sum ?final . } .