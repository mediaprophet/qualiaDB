# Comprehensive Cooperative Projects Ontology for QualiaDB

@prefix qp: <https://qualia.org/ontology/cooperative-projects#> .
@prefix sdg: <http://metadata.un.org/sdg/ontology#> .
@prefix wf: <https://wellfair.org/ns#> .
@prefix ro: <https://rightsontology.org/ns#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Core Classes
qp:Project a owl:Class .
qp:SoftwareAgent a owl:Class .
qp:SharedLedger a owl:Class .

# === PROJECT APPROACH TAXONOMY (from Gemini doc) ===
qp:ProjectApproach a owl:Class .
qp:OptimalApproach a qp:ProjectApproach ; rdfs:comment "North Star - Highest quality theoretical ideal" .
qp:PracticalApproach a qp:ProjectApproach ; rdfs:comment "Viable - Highest utility within constraints" .
qp:CompromisedApproach a qp:ProjectApproach ; rdfs:comment "Strategic trade-offs for speed/survival" .
qp:RiskyApproach a qp:ProjectApproach ; rdfs:comment "Experimental - High variance innovation" .

qp:approachType a owl:ObjectProperty ; rdfs:domain qp:Project, qp:Idea ; rdfs:range qp:ProjectApproach .

# Value-Complexity Matrix
qp:ValueComplexityQuadrant a owl:Class .
qp:QuickWin a qp:ValueComplexityQuadrant .
qp:MajorProject a qp:ValueComplexityQuadrant .
qp:FillIn a qp:ValueComplexityQuadrant .
qp:ThanklessTask a qp:ValueComplexityQuadrant .

# Technical Debt & Iron Triangle
qp:technicalDebtLevel a owl:DatatypeProperty ; rdfs:domain qp:Project ; rdfs:range xsd:float .
qp:mitigationPlan a owl:DatatypeProperty ; rdfs:domain qp:Project .
qp:expectedMultiplier a owl:DatatypeProperty ; rdfs:domain qp:Project, qp:Idea ; rdfs:range xsd:float .  # 1.2x safe to 42x high-risk

# Dual Scoping, Challenges, Brainstorming (previous work)
qp:ProjectScope a owl:Class .
qp:ImmediateApplication a owl:Class .
qp:FuturePotential a owl:Class .
qp:Challenge a owl:Class .
qp:BrainstormSession a owl:Class .
qp:Idea a owl:Class .
qp:IdeaNote a owl:Class .

qp:hasScope a owl:ObjectProperty .
qp:hasImmediateApplication a owl:ObjectProperty .
qp:hasFuturePotential a owl:ObjectProperty .
qp:addressesChallenge a owl:ObjectProperty .
qp:hasSDGGoal a owl:ObjectProperty .
qp:containsIdea a owl:ObjectProperty .
qp:genesisIdea a owl:ObjectProperty .
qp:originalSubmission a owl:ObjectProperty .