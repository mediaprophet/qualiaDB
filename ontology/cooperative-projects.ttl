# QualiaDB Cooperative Projects Ontology - Enhanced Version

@prefix qp: <https://qualia.org/ontology/cooperative-projects#> .
@prefix sdg: <http://metadata.un.org/sdg/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### PROJECT APPROACH TAXONOMY (Awesome Edition)

qp:ProjectApproach a owl:Class ;
    rdfs:comment "Strategic execution archetype balancing quality, resources, risk and long-term value." .

qp:OptimalApproach a qp:ProjectApproach ;
    rdfs:comment "The North Star - Highest theoretical quality and innovation (ignores constraints)" .

qp:PracticalApproach a qp:ProjectApproach ;
    rdfs:comment "The Viable - Highest utility within current real-world constraints" .

qp:CompromisedApproach a qp:ProjectApproach ;
    rdfs:comment "Deliberate strategic trade-offs for speed or survival" .

qp:RiskyApproach a qp:ProjectApproach ;
    rdfs:comment "Experimental high-variance path with potential for breakthrough" .

# Value-Complexity Matrix
qp:ValueComplexityQuadrant a owl:Class ;
    rdfs:comment "Quick Wins, Major Projects, Fill-ins, Thankless Tasks" .

qp:quadrantType a owl:DatatypeProperty ;
    rdfs:domain qp:ValueComplexityQuadrant ;
    rdfs:range xsd:string .

# Technical Debt & Risk
qp:technicalDebtLevel a owl:DatatypeProperty ;
    rdfs:domain qp:Project, qp:Idea ;
    rdfs:range xsd:float ;   # 0.0 = none to 1.0 = critical
    rdfs:comment "Quantified technical debt with provenance tracking" .

qp:debtMitigationPlan a owl:ObjectProperty ;
    rdfs:domain qp:Project ;
    rdfs:range xsd:string .

qp:riskFactor a owl:DatatypeProperty ;
    rdfs:domain qp:Project, qp:Idea ;
    rdfs:range xsd:float .

# Benefit / Reward Multipliers
qp:expectedMultiplier a owl:DatatypeProperty ;
    rdfs:domain qp:Project, qp:Idea ;
    rdfs:range xsd:float ;   # 1.2x safe → 42x moonshot
    rdfs:comment "Expected value multiplier considering risk/reward" .

# Link to existing frameworks
qp:hasApproach a owl:ObjectProperty ;
    rdfs:domain qp:Project ;
    rdfs:range qp:ProjectApproach .

qp:addressesScope a owl:ObjectProperty ;
    rdfs:domain qp:ProjectApproach ;
    rdfs:range qp:ProjectScope .